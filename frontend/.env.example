# Local dev: leave both unset — the app uses `/api` and Vite proxies to Django (127.0.0.1:8000).
# Optional: if Django is not on 8000, set the origin only (no /api path):
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:9000
# Optional: bypass the proxy and call the API directly (you must configure CORS on Django):
# VITE_API_URL=http://127.0.0.1:8000/api
